import seaborn as sns


sns.set_theme()


sns.get_dataset_names()


tips = sns.load_dataset("tips")
tips.head()


# relational plot
sns.set_theme()

sns.relplot(
    data=tips,
    x="total_bill",
    y="tip",
    hue="smoker",
    size="size",
    style="smoker"
)


# scatter plot
sns.scatterplot(
    data=tips,
    x="total_bill",
    y="tip",
    hue="time"
)


# bar plot
sns.barplot(
    data=tips,
    x="day",
    y="tip",
    hue="sex"
)


# box plot
sns.boxplot(
    data=tips,
    x="day",
    y="tip"
)


# histogram
penguins = sns.load_dataset("penguins")

sns.histplot(
    data=penguins,
    x="body_mass_g",
    bins=30
)


# heatmap
import matplotlib.pyplot as plt
flights = sns.load_dataset("flights")
flights_pivot = flights.pivot(index="month",columns="year",values="passengers")

sns.heatmap(
    flights_pivot,
    cmap="coolwarm",
    annot=True,
    fmt="d"
)

plt.title("Passengers Heatmap")
plt.tight_layout()


# sub plots
fig, ax = plt.subplots()

sns.lineplot(
    data=tips,
    x="day",
    y="total_bill",
    hue="sex",
    marker="o",
    ax=ax
)

ax.set_title("avg bill value for each day")
ax.set_xlabel("Days")
ax.set_ylabel("Total Bill Amount")

fig.tight_layout()



